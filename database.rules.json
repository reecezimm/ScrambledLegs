{
  "rules": {
    ".read": false,
    ".write": false,
    "events": {
      ".read": true,
      ".write": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      ".indexOn": ["start"],
      "$id": {
        "hotdogs": {
          ".write": true,
          ".validate": "newData.isNumber()"
        }
      }
    },
    "newsletterRegistrants": {
      ".write": true,
      ".read": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')"
    },
    "users": {
      ".read": true,
      ".write": true
    },
    "hotdogLogs": {
      ".read": true,
      ".write": true
    },
    "hotdogCounter": {
      ".read": true,
      ".write": true
    },
    "fcmTokens": {
      ".read": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      ".write": false,
      "$hash": {
        ".write": "$hash.matches(/^[a-f0-9]{64}$/) || (auth != null && (auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com' || root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true))",
        ".validate": "newData.hasChildren(['token']) && newData.child('token').isString()",
        "token": { ".validate": "newData.isString() && newData.val().length < 4096" },
        "createdAt": { ".validate": "newData.isNumber() || newData.val() == now" },
        "lastSeenAt": { ".validate": "newData.isNumber() || newData.val() == now" },
        "userAgent": { ".validate": "newData.isString() && newData.val().length < 500" },
        "platform": { ".validate": "newData.isString() && newData.val().length < 32" },
        "isStandalone": { ".validate": "newData.isBoolean()" },
        "uid": { ".validate": "newData.isString() && newData.val().length < 128" },
        "email": { ".validate": "newData.isString() && newData.val().length < 256" },
        "displayName": { ".validate": "newData.isString() && newData.val().length < 256" },
        "$other": { ".validate": false }
      }
    },
    "notifications": {
      ".read": true,
      ".write": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      ".indexOn": ["sentAt"]
    },
    "userProfiles": {
      ".read": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
        ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com' || root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true)",
        "isAdmin": {
          ".write": "auth != null && (auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com' || root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true)"
        },
        "displayName": {
          ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com' || root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true)"
        },
        "photoURL": {
          ".write": "auth != null && (auth.uid == $uid || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com' || root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true)"
        }
      }
    },
    "mashSessions": {
      ".read": true,
      "$eventId": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "eventMashTotals": {
      ".read": true,
      "$eventId": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid",
          ".validate": "newData.isNumber()"
        }
      }
    },
    "rsvps": {
      ".read": true,
      "$eventId": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "analyticsEvents": {
      ".read": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      ".write": false,
      ".indexOn": ["ts"],
      "$pushId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['name'])"
      }
    },
    "pendingWelcomeEmails": {
      ".read": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      ".write": false
    },
    "aiCache": {
      ".read": true,
      ".write": "auth != null",
      "$key": {
        ".validate": "(newData.hasChildren(['value', 'generatedAt']) && newData.child('value').isString()) || (newData.hasChild('lock') && newData.child('lock').isBoolean())"
      }
    },
    "errorLogs": {
      ".read": "auth != null && (root.child('userProfiles').child(auth.uid).child('isAdmin').val() == true || auth.token.email == 'gm@thescrambledlegs.com' || auth.token.email == 'coach@thescrambledlegs.com')",
      "$pushId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['msg', 'ts'])"
      }
    }
  }
}
